<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xyronix Studios | Resmi Web Sitesi</title>
    <style>
        :root {
            --primary: #FF8C00;
            --bg: #050505;
            --section-bg: #080808;
            --text: #ffffff;
            --text-muted: #888888;
            --glass: rgba(255, 255, 255, 0.03);
            --border: rgba(255, 255, 255, 0.1);
            --nav-bg: rgba(0, 0, 0, 0.9);
            --chat-bg: #0a0a0a;
            --msg-bot: #1a1a1a;
            --hero-gradient: radial-gradient(circle at 80% 20%, rgba(255, 140, 0, 0.05) 0%, transparent 40%);
        }

        body.day-mode {
            --bg: #F5F5F7;
            --section-bg: #ffffff;
            --text: #1d1d1f;
            --text-muted: #86868b;
            --glass: rgba(0, 0, 0, 0.02);
            --border: rgba(0, 0, 0, 0.1);
            --nav-bg: rgba(255, 255, 255, 0.8);
            --chat-bg: #ffffff;
            --msg-bot: #f0f0f0;
            --hero-gradient: radial-gradient(circle at 80% 20%, rgba(255, 140, 0, 0.1) 0%, transparent 40%);
        }

        html { scroll-behavior: smooth; }
        body {
            background-color: var(--bg);
            color: var(--text);
            font-family: 'Inter', sans-serif;
            margin: 0;
            overflow-x: hidden;
            transition: background-color 1s ease, color 1s ease;
        }

        nav {
            display: flex; justify-content: space-between; align-items: center;
            padding: 20px 8%; background: var(--nav-bg); backdrop-filter: blur(20px);
            position: fixed; width: 100%; z-index: 1000; box-sizing: border-box;
            border-bottom: 1px solid var(--border);
        }

        .logo { font-weight: 800; font-size: 1.4rem; color: var(--text); letter-spacing: 1px; }
        .logo span { color: var(--primary); }

        .hero { height: 100vh; display: flex; align-items: center; justify-content: space-between; padding: 0 8%; background: var(--hero-gradient); }
        .hero-content h1 { font-size: 4.2rem; line-height: 1.1; margin: 0; font-weight: 900; min-height: 150px; }
        .hero-content h1 span { color: var(--primary); display: block; }
        .typewriter::after { content: "|"; animation: blink 0.7s infinite; color: var(--primary); }
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

        .xyro-main-img { width: 480px; filter: drop-shadow(0 0 40px rgba(255,140,0,0.1)); }

        .section-padding { padding: 100px 8%; }
        .content-card {
            background: var(--glass); padding: 50px; border-radius: 40px;
            border: 1px solid var(--border); max-width: 950px; margin: 0 auto;
        }

        .crew-container { display: flex; justify-content: center; gap: 30px; flex-wrap: wrap; margin-top: 60px; }
        .crew-member { cursor: pointer; transition: 0.3s; width: 180px; text-align: center; }
        .crew-member:hover { transform: translateY(-10px); }
        .avatar-bg { 
            width: 160px; height: 160px; background: var(--glass); 
            border: 2px solid var(--border); border-radius: 40px; 
            margin: 0 auto 15px; display: flex; align-items: center; justify-content: center;
            overflow: hidden;
        }
        .avatar-bg img { width: 100%; height: 100%; object-fit: cover; }

        .btn-top, .support-btn {
            background: var(--primary); color: white !important;
            padding: 12px 25px; border-radius: 50px; font-weight: bold;
            text-decoration: none; border: none; cursor: pointer; transition: 0.3s;
        }
        .support-btn { display: inline-block; margin-top: 30px; padding: 15px 40px; }

        .social-links { margin-top: 25px; display: flex; justify-content: center; gap: 40px; align-items: center; }
        .social-links a { 
            display: flex; align-items: center; gap: 10px;
            color: var(--text); text-decoration: none; font-weight: bold; 
            opacity: 0.7; transition: 0.3s; 
        }
        .social-links a:hover { color: var(--primary); opacity: 1; transform: scale(1.05); }
        .social-icon { width: 24px; height: 24px; object-fit: contain; }
        body.day-mode .github-icon { filter: invert(1); }

        .modal {
            display: none; position: fixed; z-index: 3000; left: 0; top: 0;
            width: 100%; height: 100%; background: rgba(0,0,0,0.9); backdrop-filter: blur(10px);
        }
        .modal-content {
            background: var(--bg); margin: 8% auto; padding: 40px;
            border: 1px solid var(--border); border-radius: 40px; width: 85%; max-width: 500px;
            position: relative; animation: modalAppear 0.3s ease-out;
        }
        @keyframes modalAppear { from {opacity: 0; transform: scale(0.95);} to {opacity: 1; transform: scale(1);} }
        .close-modal { position: absolute; right: 30px; top: 20px; font-size: 30px; cursor: pointer; color: var(--text-muted); }

        footer { padding: 60px 8%; border-top: 1px solid var(--border); text-align: center; }
    </style>
</head>
<body>

    <nav>
        <div class="logo">XYRONIX <span>STUDIOS</span></div>
        <div class="nav-links">
            <a href="#apps" style="color:var(--text); text-decoration:none; margin-right:20px;">Projeler</a>
            <a href="#about" style="color:var(--text); text-decoration:none; margin-right:20px;">Hakkımızda</a>
            <a href="mailto:xyronixstudios@gmail.com" class="btn-top">İletişim</a>
        </div>
    </nav>

    <section id="home" class="hero">
        <div class="hero-content">
            <h1 id="typewriter" class="typewriter"></h1>
            <p style="color: var(--text-muted); font-size: 1.1rem; margin-top: 20px;">Xyronix Karargâhı - Gelecek Burada Yazılıyor.</p>
            <a href="#apps" class="btn-top" style="padding: 18px 45px; margin-top: 30px; display: inline-block;" onclick="playClick()">Neler Yapıyoruz?</a>
        </div>
        <img src="Xyro.png" alt="Xyro" class="xyro-main-img">
    </section>

    <section id="apps" class="section-padding">
        <div class="content-card">
            <h2 style="font-size: 2.2rem; margin-bottom: 30px; text-align: center;">📱 Uygulamalar ve Oyunlar</h2>
            <div class="empty-state" style="text-align: center; padding: 40px; border: 2px dashed var(--border); border-radius: 20px;">
                <p style="font-size: 1.2rem; color: var(--primary);">Şu anlık boş...</p>
                <p style="color: var(--text-muted);">Yeni nesil projelerimiz çok yakında burada listelenecek.</p>
            </div>
        </div>
    </section>

    <section id="about" class="section-padding" style="background: var(--section-bg);">
        <div class="content-card">
            <h2 style="font-size: 2.2rem; margin-bottom: 30px; text-align: center;">🧠 Hakkımızda – Xyronix Studios</h2>
            <div style="line-height: 1.7; color: var(--text-muted);">
                <p>Biz <b>Xyronix Studios</b>, bağımsız bir küçük oyun geliştirici grubuyuz. 2D ve 3D oyunlar geliştiriyoruz. Amacımız sadece oyun yapmak değil; oynanabilir, eğlenceli ve kendi tarzı olan deneyimler oluşturmak.</p>
                <p>Fikirden tasarıma, tasarımdan oyuna kadar sürecin her aşamasını kendi ekibimizle yürütüyoruz. Öğrenme ve gelişim bizim için önemli. Oyun tasarımında ve kullanıcı deneyiminde sürekli kendimizi geliştiriyoruz.</p>
                <h3 style="color: var(--text); margin-top: 30px;">🚀 Ne yapıyoruz?</h3>
                <ul style="list-style: none; padding: 0;">
                    <li>• 2D / 3D oyun geliştirme</li>
                    <li>• Bağımsız oyun projeleri</li>
                    <li>• Deneysel oyun mekanikleri</li>
                    <li>• Topluluk odaklı içerikler</li>
                </ul>
                <h3 style="color: var(--text);">💬 Topluluk</h3>
                <p>Bizim için oyuncular sadece “kullanıcı” değil, gelişim sürecinin bir parçasıdır.</p>
                <div style="text-align: center;">
                    <button class="support-btn" onclick="copyYoutube()">📢 Bizi Destekle</button>
                </div>
            </div>

            <h2 style="text-align:center; margin-top: 80px; margin-bottom: 40px;">🚀 Karargâh Üyeleri</h2>
            <div class="crew-container">
                <div class="crew-member" onclick="openMember('kaizer')">
                    <div class="avatar-bg"><img src="Kaizer.jpeg" alt="Kaizer"></div>
                    <h3>Kaizer</h3>
                    <p style="color:var(--primary); font-size:0.85rem;">Studio Manager</p>
                </div>
                <div class="crew-member" onclick="openMember('larry')">
                    <div class="avatar-bg"><img src="Larry.jpeg" alt="Larry"></div>
                    <h3>Larry</h3>
                    <p style="color:var(--primary); font-size:0.85rem;">Görsel & UI Tasarım</p>
                </div>
                <div class="crew-member" onclick="openMember('aethelgard')">
                    <div class="avatar-bg"><img src="Aethelgard.png" alt="Aethelgard"></div>
                    <h3>Aethelgard</h3>
                    <p style="color:var(--primary); font-size:0.85rem;">Görsel & UI Tasarım</p>
                </div>
            </div>
        </div>
    </section>

    <div id="memberModal" class="modal">
        <div class="modal-content">
            <span class="close-modal" onclick="closeMember()">&times;</span>
            <h2 id="memberName" style="color: var(--primary);">İsim</h2>
            <h4 id="memberRole" style="margin-top: 0; opacity: 0.8;">Rol</h4>
            <p id="memberDuty" style="color: var(--text-muted); margin-top: 20px; line-height: 1.6;"></p>
            <blockquote id="memberQuote" style="font-style: italic; color: var(--primary); border-left: 2px solid var(--primary); padding-left: 15px;"></blockquote>
        </div>
    </div>

    <div class="chat-wrapper">
        <img src="Xyro_Yardımcı.png" alt="Helper" class="chat-icon-mini" onclick="toggleChat()" style="width: 75px; height: 75px; cursor: pointer;">
    </div>

    <footer>
        <p style="color: var(--text); font-weight: bold; margin-bottom: 10px;">📫 İletişim</p>
        <a href="mailto:xyronixstudios@gmail.com" style="color: var(--primary); text-decoration: none;">xyronixstudios@gmail.com</a>
        
        <div class="social-links">
            <a href="https://github.com/xyronixstudios-dot" target="_blank">
                <img src="https://github.githubassets.com/images/modules/logos_page/GitHub-Mark.png" class="social-icon github-icon" alt="GitHub" style="filter: invert(1);">
                GITHUB
            </a>
            <a href="https://youtube.com/@xyronixstudioss?si=G5CRPFPkW50rkyJQ" target="_blank">
                <img src="https://upload.wikimedia.org/wikipedia/commons/e/ef/Youtube_logo.png" class="social-icon" alt="YouTube">
                YOUTUBE
            </a>
        </div>
        <p style="color: var(--text-muted); margin-top: 30px; font-size: 0.8rem;">© 2026 Xyronix Studios</p>
    </footer>

    <script>
        function checkTime() {
            const hour = new Date().getHours();
            if (hour >= 7 && hour < 19) { document.body.classList.add('day-mode'); } 
            else { document.body.classList.remove('day-mode'); }
        }
        setInterval(checkTime, 60000);
        checkTime();

        function copyYoutube() {
            const link = "https://youtube.com/@xyronixstudioss?si=G5CRPFPkW50rkyJQ";
            navigator.clipboard.writeText(link).then(() => {
                playClick();
                alert("YouTube linki kopyalandı! Desteğin için teşekkürler şef! 🚀");
            });
        }

        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        function playSound(f, t, d) {
            const o = audioCtx.createOscillator(); const g = audioCtx.createGain();
            o.type = t; o.frequency.setValueAtTime(f, audioCtx.currentTime);
            g.gain.setValueAtTime(0.04, audioCtx.currentTime); o.connect(g); g.connect(audioCtx.destination);
            o.start(); o.stop(audioCtx.currentTime + d);
        }
        function playClick() { playSound(800, 'sine', 0.1); }

        const text = "Oyna. Kullan.\nGüvende Kal.";
        let i = 0;
        function typeWriter() {
            if (i < text.length) {
                document.getElementById("typewriter").innerHTML += text.charAt(i) === "\n" ? "<br><span>" : text.charAt(i);
                if(text.charAt(i) !== " ") playSound(220, 'triangle', 0.05);
                i++; setTimeout(typeWriter, 120);
            }
        }
        window.onload = typeWriter;

        const crewData = {
            kaizer: { name: "Kaizer", role: "Studio Manager", duty: "Xyronix Studios lideri. Stratejik yönetim ve vizyondan sorumlu.", quote: "Vizyon, görülmeyeni görmektir." },
            larry: { name: "Larry", role: "Görsel & UI Tasarım", duty: "Sistem arayüzleri ve görsel dillerin kurgulanmasını sağlar.", quote: "Tasarım, bir problemi çözmektir." },
            aethelgard: { name: "Aethelgard", role: "Görsel & UI Tasarım", duty: "Kullanıcı deneyimi ve kreatif grafik tasarımları koordine eder.", quote: "Güzellik, ayrıntılarda saklıdır." }
        };

        function openMember(id) {
            playClick(); const m = crewData[id];
            document.getElementById('memberName').innerText = m.name;
            document.getElementById('memberRole').innerText = m.role;
            document.getElementById('memberDuty').innerText = m.duty;
            document.getElementById('memberQuote').innerText = `"${m.quote}"`;
            document.getElementById('memberModal').style.display = "block";
        }
        function closeMember() { document.getElementById('memberModal').style.display = "none"; }
        function toggleChat() { playClick(); alert("Asistan Xyro: Oyna. Kullan. Güvende Kal."); }
    </script>
</body>
</html>
